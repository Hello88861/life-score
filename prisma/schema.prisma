generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth & User ─────────────────────────────────────────────
model User {
  id        String        @id @default(cuid())
  email     String        @unique
  password  String
  name      String
  age       Int
  status    String        // "working" | "studying"
  createdAt DateTime      @default(now())
  records   DailyRecord[]
  goals     Goals?
  tasks     Task[]
  posts     Post[]
}

// ─── Blog / Journal ──────────────────────────────────────────
model Post {
  id        Int      @id @default(autoincrement())
  userId    String
  title     String
  slug      String   @unique
  content   String
  excerpt   String   @default("")
  coverUrl  String   @default("")
  type      String   @default("blog")  // "blog" | "journal"
  published Boolean  @default(true)
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── LifeScore ───────────────────────────────────────────────
model Goals {
  id             String   @id @default(cuid())
  userId         String   @unique
  sleepBedtime   String   // "23:00"
  sleepWaketime  String   // "07:00"
  waterTarget    Int
  exerciseTarget Int
  readingTarget  Int
  learningTarget Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyRecord {
  id                   String   @id @default(cuid())
  userId               String
  date                 DateTime @db.Date
  bedtime              String
  waketime             String
  water                Int
  exercise             Int
  reading              Int
  learning             Int
  sleepScore           Float
  waterScore           Float
  exerciseScore        Float
  readingScore         Float
  learningScore        Float
  disciplineScore      Float
  disciplineMultiplier Float
  totalScore           Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  title     String
  category  String   @default("general")
  done      Boolean  @default(false)
  date      String   // YYYY-MM-DD
  time      String   @default("")
  urgent    Boolean  @default(false)
  important Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
